# ─────────────────────────────────────────────
# XentoryBet — Variables de entorno
# ─────────────────────────────────────────────

# API-Football (gratuita, 100 req/día)
# Regístrate en: https://dashboard.api-football.com
# Plan FREE: no necesita tarjeta de crédito
VITE_API_FOOTBALL_KEY=tu_key_aqui

# Gemini AI (gratuita)
# Obtén tu key en: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=tu_key_aqui

# The Odds API — cuotas en tiempo real por casa de apuestas
# Regístrate en: https://the-odds-api.com (plan FREE: 500 req/mes)
# Sin esta key las cuotas se estiman del modelo estadístico (no son reales)
VITE_ODDS_API_KEY=tu_key_aqui

# URLs del ecosistema
VITE_HUB_URL=http://localhost:4000
