# ═══════════════════════════════════════════
#   NEXUS ECOSYSTEM — Variables de entorno
#   Copia este archivo a .env en la raíz
# ═══════════════════════════════════════════

# ── URLS de cada app ──────────────────────
VITE_HUB_URL=http://localhost:4000
VITE_MARKET_URL=http://localhost:3000
VITE_BETS_URL=http://localhost:3001

# ── Gemini AI (NexusMarket + NexusBet) ───
# Obtén tu key en: https://aistudio.google.com
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── API-Football (NexusBet) ───────────────
# Obtén tu key en: https://www.api-football.com
# Plan gratuito: 100 peticiones/día
VITE_API_FOOTBALL_KEY=your_api_football_key_here

# ── Stripe ────────────────────────────────
# Obtén tus keys en: https://dashboard.stripe.com
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Stripe Price IDs ──────────────────────
# Crear en Stripe Dashboard → Products
STRIPE_PRICE_MARKET_PRO_MONTHLY=price_xxx
STRIPE_PRICE_MARKET_PRO_YEARLY=price_xxx
STRIPE_PRICE_MARKET_ELITE_MONTHLY=price_xxx
STRIPE_PRICE_MARKET_ELITE_YEARLY=price_xxx
STRIPE_PRICE_BETS_PRO_MONTHLY=price_xxx
STRIPE_PRICE_BETS_PRO_YEARLY=price_xxx
STRIPE_PRICE_BETS_ELITE_MONTHLY=price_xxx
STRIPE_PRICE_BETS_ELITE_YEARLY=price_xxx
STRIPE_PRICE_BUNDLE_MONTHLY=price_xxx
STRIPE_PRICE_BUNDLE_YEARLY=price_xxx

# ── Telegram ──────────────────────────────
# 1. Habla con @BotFather en Telegram
# 2. Usa /newbot para crear el bot
# 3. Añade el bot como admin a tus canales
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_MARKET_PRO_CHANNEL_ID=-100your_channel_id
TELEGRAM_MARKET_ELITE_CHANNEL_ID=-100your_channel_id
TELEGRAM_BETS_PRO_CHANNEL_ID=-100your_channel_id
TELEGRAM_BETS_ELITE_CHANNEL_ID=-100your_channel_id

# ── Entorno ───────────────────────────────
NODE_ENV=development
