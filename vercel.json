{
  "version": 2,
  "buildCommand": "npm run build --workspace=apps/bet",
  "outputDirectory": "apps/bet/dist",
  "functions": {
    "api/*.ts": { "runtime": "@vercel/node@3" }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
